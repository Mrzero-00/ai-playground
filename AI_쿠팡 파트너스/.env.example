# Anthropic (콘텐츠 생성)
ANTHROPIC_API_KEY=

# Instagram Graph API (자동 게시)
# - IG_USER_ID: Instagram 비즈니스/크리에이터 계정 ID (Facebook 페이지에 연결됨)
# - IG_ACCESS_TOKEN: instagram_content_publish 권한을 가진 장기 액세스 토큰
IG_USER_ID=
IG_ACCESS_TOKEN=
GRAPH_API_VERSION=v21.0

# 쿠팡 파트너스 Open API (HMAC 인증)
# - 키가 있으면 실제 상품을 자동 수집(검색/골드박스), 없으면 샘플 아이템 사용
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
# subId: 채널별 트래킹용 (선택). 응답 productUrl(딥링크)에 반영됨
COUPANG_SUB_ID=
# SEARCH_KEYWORD 가 있으면 키워드 검색, 없으면 골드박스(오늘의 딜)
SEARCH_KEYWORD=
SEARCH_LIMIT=5

# DRY_RUN=1 이면 실제 게시하지 않고 콘텐츠만 출력
DRY_RUN=
