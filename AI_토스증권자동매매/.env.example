OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ENABLED=false
# Free news and official SEC filings
FINNHUB_API_KEY=
# SEC requires a descriptive user agent with a contact email.
SEC_USER_AGENT=AITossTradingBot your-email@example.com
WATCHLIST=AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA,AMD,AVGO,NFLX
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379
PORT=4000
LIVE_TRADING_ENABLED=false
LIVE_TRADING_ENVIRONMENT=sandbox
LIVE_PRODUCTION_ACK=

# Toss Securities Open API (server only)
TOSS_INVEST_CLIENT_ID=
TOSS_INVEST_CLIENT_SECRET=
TOSS_INVEST_ACCOUNT_SEQ=
TOSS_INVEST_MODE=read_only
# Set only after paper/shadow validation. Exact opt-in string required for real orders.
TOSS_INVEST_LIVE_CONFIRM=

# 2-3 week read-only shadow observation
SHADOW_SYMBOLS=AAPL,MSFT
SHADOW_POLL_SECONDS=30
SHADOW_DURATION_DAYS=21
SHADOW_LOG_PATH=var/shadow/snapshots.jsonl

# News + SEC paper trading. Real Toss orders are never submitted by this app.
PAPER_POLL_SECONDS=30
PAPER_NEWS_POLL_SECONDS=300
PAPER_DURATION_DAYS=21
PAPER_STARTING_EQUITY=100000
PAPER_RISK_PER_TRADE_PERCENT=0.25
PAPER_DAILY_LOSS_LIMIT_PERCENT=1
PAPER_MAX_POSITIONS=3
PAPER_SLIPPAGE_BPS=5
PAPER_COMMISSION_PER_ORDER=1
PAPER_HOLDING_MINUTES=360
PAPER_STATE_PATH=var/paper/state.json
PAPER_EVENT_LOG_PATH=var/paper/events.jsonl
