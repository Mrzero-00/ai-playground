PORT=4000

# Server only. Never expose the service role key to browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Data providers are attached behind provider interfaces.
FINNHUB_API_KEY=
SEC_USER_AGENT=

# AI analysis is optional; deterministic risk rules do not depend on it.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_ENABLED=false

# Automated execution is isolated and defaults to DRY_RUN. R1 hard-blocks LIVE startup.
# Never expose these values to browser code.
EXECUTION_HOST=127.0.0.1
EXECUTION_PORT=4100
EXECUTION_SERVICE_TOKEN=
EXECUTION_MODE=DRY_RUN
AUTO_TRADING_ENABLED=false
LIVE_TRADING_ACK=
EXECUTION_RELEASE_EVIDENCE_VERIFIED=false
EXECUTION_RELEASE_EVIDENCE_ID=
EXECUTION_ALLOWED_ACCOUNTS=
EXECUTION_KILL_SWITCH_OPEN=true
EXECUTION_RECONCILIATION_HEALTHY=false
EXECUTION_MAX_SINGLE_ORDER_NOTIONAL=100000
EXECUTION_MAX_PRICE_DRIFT_BPS=50
EXECUTION_MAX_DATA_AGE_SECONDS=300
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# Internal public.broker_accounts.id. Do not put the Toss account number here.
TOSS_ACCOUNT_ID=
# Toss GET /api/v1/accounts result.accountSeq used only in the broker header.
TOSS_ACCOUNT_SEQ=
